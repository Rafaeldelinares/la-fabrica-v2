[Unit]
Description=Infraestructura Dashboard Frontend
After=network.target

[Service]
Type=simple
User=rafael
WorkingDirectory=/opt/fabrica/infraestructura-dashboard/frontend
ExecStart=/usr/bin/python3 -m http.server 8000
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
